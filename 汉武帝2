class jilei
{
public:
    void get_gjl(int gjl)
    {
        m_gjl = gjl;
    }
    void get_fyl(int fyl)
    {
        m_fyl = fyl;
    }
    void get_hp(int hp)
    {
        m_hp = hp;
    }
    void add_hp(int hp)
    {
        m_hp += hp;
    }
    int set_gjl()
    {
        return m_gjl;
    }
    int set_fyl()
    {
        return m_fyl;
    }
    int set_hp()
    {
        return m_hp;
    }
private:
    int m_gjl; //攻击力
    int m_fyl;  // 防御力
